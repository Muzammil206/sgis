# =============================================================================
# SGIS Backend Configuration
# Copy this file to .env and fill in your actual values
# =============================================================================

# PostgreSQL Connection — Choose ONE option below:

# OPTION 1: Local PostgreSQL (for docker-compose or local development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sgis
DB_USER=postgres
DB_PASSWORD=postgres

# OPTION 2: Remote Neon Database (comment out Option 1 if using this)
# DATABASE_URL=postgresql://user:password@host/database?sslmode=require&channel_binding=require

# API Server
PORT=4000
NODE_ENV=development

# Frontend (for CORS)
FRONTEND_ORIGIN=http://localhost:5173

# JWT Authentication (CHANGE THIS in production!)
JWT_SECRET=change_this_to_a_long_random_secret_minimum_32_characters_long
JWT_EXPIRES_IN=8h
